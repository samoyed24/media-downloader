# 账号配置
QB_USERNAME=admin
QB_PASSWORD=your_qbittorrent_password
JELLYFIN_USERNAME=admin
JELLYFIN_PASSWORD=your_jellyfin_password

# 端口配置
WEB_PORT=5001
QB_PORT=8080
JELLYFIN_PORT=8096

# 数据路径（NAS 部署时改成实际路径，如 /volume1/docker/programme-downloader/...）
DOWNLOAD_PATH=./downloads
DATA_PATH=./data
MEDIA_PATH=./media
QB_CONFIG_PATH=./qbittorrent_config
JELLYFIN_CONFIG_PATH=./jellyfin_config
